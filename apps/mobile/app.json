{
  "expo": {
    "name": "Vekino",
    "slug": "vekino",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vekino",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.vekino.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vekino.app",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vekino necesita acceso a tus fotos para el avatar de perfil.",
          "cameraPermission": "Vekino necesita la cámara para tomar tu foto de perfil."
        }
      ],
      "expo-document-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Vekino necesita la cámara para escanear el QR de asistencia en asambleas.",
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#042046"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd586790-b6fc-4c11-b8ec-c655b3775186"
      }
    },
    "owner": "santiagosuescun07"
  }
}
