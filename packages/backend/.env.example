# Convex — copiar valores al deployment con:
#   bunx convex env set NOMBRE "valor"
#
# Auth
# BETTER_AUTH_SECRET=
# SITE_URL=https://tu-dominio-web.com
# MASTER_LOGIN_PASSWORD=
# Google OAuth (cliente tipo "Web application" en Google Cloud)
# Redirect URI: https://TU-DEPLOYMENT.convex.site/api/auth/callback/google
# Origin autorizado: https://TU-DEPLOYMENT.convex.site
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Correo (Brevo) — mismas vars que VekinoApi
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=contacto@vekino.com
# BREVO_SENDER_NAME=Equipo de Vekino
